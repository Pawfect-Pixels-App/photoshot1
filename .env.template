# Environment Variables Template
# Copy this file to .env.local and fill in the values

# ============================================
# REQUIRED - Database
# ============================================
# PostgreSQL connection string
# Local: postgresql://photoshot:photoshot@localhost:5432/photoshot
# Neon: postgres://user:pass@xxx.neon.tech/photoshot?sslmode=require
# Supabase: postgres://postgres:pass@xxx.supabase.co:5432/postgres
DATABASE_URL=

# ============================================
# REQUIRED - Application
# ============================================
# Your application URL
# Local: http://localhost:3000
# Production: https://your-domain.com
NEXTAUTH_URL=

# Random string for authentication (generate with: openssl rand -base64 32)
SECRET=

# ============================================
# REQUIRED - AWS S3 Storage
# ============================================
S3_UPLOAD_KEY=
S3_UPLOAD_SECRET=
S3_UPLOAD_BUCKET=
S3_UPLOAD_REGION=

# ============================================
# REQUIRED - Replicate AI
# ============================================
REPLICATE_API_TOKEN=
REPLICATE_USERNAME=

# Training identifier (3 Unicode characters recommended, e.g., "abc", "xyz")
NEXT_PUBLIC_REPLICATE_INSTANCE_TOKEN=

# ============================================
# OPTIONAL - Replicate Settings
# ============================================
REPLICATE_MAX_TRAIN_STEPS=3000
REPLICATE_NEGATIVE_PROMPT="cropped face, cover face, cover visage, mutated hands"
REPLICATE_HD_VERSION_MODEL_ID=

# ============================================
# OPTIONAL - Email (for authentication)
# ============================================
# Sender email address
EMAIL_FROM=

# SMTP server URL
# Local (docker-compose): smtp://localhost:25
# SendGrid: smtp://apikey:YOUR_API_KEY@smtp.sendgrid.net:587
# Mailgun: smtp://USERNAME:PASSWORD@smtp.mailgun.org:587
# AWS SES: smtp://USERNAME:PASSWORD@email-smtp.REGION.amazonaws.com:587
EMAIL_SERVER=smtp://localhost:25

# ============================================
# OPTIONAL - Stripe (for payments)
# ============================================
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_STUDIO_PRICE=
NEXT_PUBLIC_STUDIO_SHOT_AMOUNT=

# ============================================
# OPTIONAL - OpenAI (for prompt wizard)
# ============================================
OPENAI_API_KEY=
OPENAI_API_SEED_PROMPT=

# ============================================
# DEVELOPMENT ONLY
# ============================================
# Disable TLS verification for local docker-compose setup
# NODE_TLS_REJECT_UNAUTHORIZED="0"
